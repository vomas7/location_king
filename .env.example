# Скопируй этот файл в .env и заполни своими значениями
# cp .env.example .env

# ─── Игровая БД ───────────────────────────────
POSTGRES_USER=geogame
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_DB=geogame

# ─── Redis ────────────────────────────────────
REDIS_PASSWORD=changeme_redis_password

# ─── Keycloak ─────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=changeme_admin_password
KEYCLOAK_REALM=geogame
KEYCLOAK_CLIENT_ID=geogame-frontend

# ─── Keycloak БД ──────────────────────────────
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=changeme_kc_password
KEYCLOAK_DB=keycloak

# ─── Backend ──────────────────────────────────
SECRET_KEY=changeme_generate_with_openssl_rand_hex_32
DEBUG=false

# ─── Домен (для nginx и Keycloak) ─────────────
DOMAIN=yourdomain.com
