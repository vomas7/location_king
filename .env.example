# Location King - Production Configuration
# Скопируйте этот файл в .env и отредактируйте

# PostgreSQL Database
POSTGRES_USER=locationking
POSTGRES_PASSWORD=your_strong_password_here
POSTGRES_DB=location_king

# Redis
REDIS_PASSWORD=your_redis_password_here

# Application URLs
DATABASE_URL=postgresql+asyncpg://locationking:your_strong_password_here@postgres:5432/location_king
REDIS_URL=redis://:your_redis_password_here@redis:6379/0

# Keycloak Authentication
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=your_keycloak_admin_password_here
KEYCLOAK_URL=https://your-domain.ru/auth  # Например: https://locationking.ru/auth
KEYCLOAK_REALM=location-king
KEYCLOAK_CLIENT_ID=location-king-client

# Satellite Imagery
# По умолчанию используется ESRI World Imagery (бесплатно)
# Mapbox можно использовать как запасной вариант
MAPBOX_ACCESS_TOKEN=

# Application Settings
DEBUG=false