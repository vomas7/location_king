# Production Environment for Location King
# Домен: locationking.ru
# Поддомены:
#   - locationking.ru (основное приложение)
#   - auth.locationking.ru (Keycloak)
#   - api.locationking.ru (API)

# ─────────────────────────────────────────
# DOMAIN CONFIGURATION
# ─────────────────────────────────────────
DOMAIN=locationking.ru
KEYCLOAK_HOSTNAME=auth.locationking.ru
API_HOSTNAME=api.locationking.ru

# ─────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────
POSTGRES_USER=locationking_prod
POSTGRES_PASSWORD=strong_production_password_here
POSTGRES_DB=location_king_prod
DATABASE_URL=postgresql+asyncpg://locationking_prod:strong_production_password_here@postgres:5432/location_king_prod

# ─────────────────────────────────────────
# REDIS
# ─────────────────────────────────────────
REDIS_PASSWORD=strong_redis_password_here
REDIS_URL=redis://:strong_redis_password_here@redis:6379/0

# ─────────────────────────────────────────
# KEYCLOAK
# ─────────────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=strong_keycloak_admin_password_here
KEYCLOAK_URL=https://auth.locationking.ru
KEYCLOAK_REALM=location-king
KEYCLOAK_CLIENT_ID=location-king-client
KEYCLOAK_DB=keycloak_prod
KEYCLOAK_DB_USER=keycloak_prod
KEYCLOAK_DB_PASSWORD=strong_keycloak_db_password_here

# ─────────────────────────────────────────
# SATELLITE IMAGERY
# ─────────────────────────────────────────
# По умолчанию используется ESRI World Imagery (бесплатно)
# Mapbox можно использовать как запасной вариант
MAPBOX_ACCESS_TOKEN=

# ─────────────────────────────────────────
# APPLICATION
# ─────────────────────────────────────────
DEBUG=false
LOG_LEVEL=INFO

# ─────────────────────────────────────────
# SECURITY
# ─────────────────────────────────────────
# Секретный ключ для JWT (сгенерировать: openssl rand -hex 32)
SECRET_KEY=generate_strong_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ─────────────────────────────────────────
# CORS
# ─────────────────────────────────────────
CORS_ORIGINS=https://locationking.ru,https://www.locationking.ru
CORS_CREDENTIALS=true

# ─────────────────────────────────────────
# RATE LIMITING
# ─────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000