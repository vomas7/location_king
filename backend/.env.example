# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/location_king

# Redis
REDIS_URL=redis://localhost:6379/0

# Keycloak (пока не используется)
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=location-king
KEYCLOAK_CLIENT_ID=location-king-client

# Mapbox (для космических снимков)
# Получите токен на https://account.mapbox.com/
MAPBOX_ACCESS_TOKEN=your_mapbox_access_token_here

# Application
DEBUG=true